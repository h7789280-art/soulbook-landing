---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { SITE_URL } from '../../lib/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const site = SITE_URL;
const path = `/blog/${post.id}/`;
const url = new URL(path, site).href;
const image = new URL(post.data.ogImage ?? '/og-cover.png', site).href;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  inLanguage: 'ru',
  mainEntityOfPage: url,
  image,
  author: { '@type': 'Organization', name: 'Вершина Души', url: site },
  publisher: { '@type': 'Organization', name: 'Вершина Души', url: site },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: `${site}/` },
    { '@type': 'ListItem', position: 2, name: 'Блог', item: `${site}/blog/` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: url },
  ],
};

const fmtDate = post.data.pubDate.toLocaleDateString('ru-RU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base
  title={`${post.data.title} — Вершина Души`}
  description={post.data.description}
  canonical={path}
  ogType="article"
  ogImage={post.data.ogImage ?? '/og-cover.png'}
  noindex={post.data.draft}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <main class="wrap hub">
    <a class="hub-back" href="/blog/">← Все статьи</a>
    <span class="hub-cat">{post.data.category}</span>
    <h1>{post.data.title}</h1>
    <p class="hub-meta">
      <time datetime={post.data.pubDate.toISOString()}>{fmtDate}</time>
    </p>
    <article class="prose">
      <Content />
    </article>
  </main>
</Base>
