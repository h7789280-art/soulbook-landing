---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { groupByCategory, faqDescription } from '../../lib/faq';

const all = await getCollection('faq');
const groups = groupByCategory(all);
const published = all.filter((f) => !f.data.draft);

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: published.map((f) => ({
    '@type': 'Question',
    name: f.data.title,
    acceptedAnswer: { '@type': 'Answer', text: faqDescription(f) },
  })),
};
---

<Base
  title="База знаний — Вершина Души"
  description="Ответы на вопросы о Матрице Судьбы, арканах, карме, предназначении, роде, деньгах, Human Design и самопознании — от команды «Вершина Души»."
  canonical="/faq/"
>
  {published.length > 0 && (
    <Fragment slot="head">
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    </Fragment>
  )}

  <main class="wrap hub">
    <a class="hub-back" href="/">← На главную</a>
    <h1>База знаний</h1>
    <p class="lead">Вопросы и ответы о Матрице Судьбы, Human Design, арканах, предназначении и самопознании.</p>

    {published.length === 0 ? (
      <p class="hub-empty">Скоро здесь появятся ответы на вопросы.</p>
    ) : (
      groups.map((group) => (
        <section class="faq-group">
          <h2>{group.label}</h2>
          <ul class="faq-index">
            {group.items.map((item) => (
              <li>
                <a href={`/faq/${item.id}/`}>{item.data.title}</a>
              </li>
            ))}
          </ul>
        </section>
      ))
    )}
  </main>
</Base>
